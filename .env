## Put your bot token here
TOKEN=your_bot_token_here

## Put your MongoDB URI here (you can get it from https://www.mongodb.com/cloud/atlas)
MONGODB_URI=your_mongodb_uri_here

##Put your bot's owner ID here (you can get it by enabling developer mode in Discord and right-clicking on your user)
BOT_OWNER_ID=your_owner_id_here

##Put the IDs of users who should have admin access to the bot, separated by commas (no spaces)
ADMIN_IDS=your_admin_ids_here

##Put the prefix you want to use for your bot's commands here (e.g. "!" or "?")
PREFIX=your_prefix_here

##Enable or disable syncing of emojis from the server to the bot (set to "true" or "false")
SYNC_EMOJI=false

##Extra configuration options for the bot
##Put your top.gg token here (you can get it from https://top.gg/dashboard/bots/your-bot-id)
TOPGG_TOKEN=your_topgg_token_here

##Put your top.gg webhook password here (you can set this to any string, but make sure to use the same string in your top.gg webhook configuration)
TOPGG_WEBHOOK_PASSWORD=your_webhook_password_here

##Put the port number you want to use for the top.gg webhook server (make sure this port is open and not used by other applications)
TOPGG_WEBHOOK_PORT=your_webhook_port_here
